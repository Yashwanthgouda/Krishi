# ─────────────────────────────────────────────────────────────────────────────
# Krishi Node.js Backend — Environment Variables
# Copy this file to .env for local dev, or set these in Render dashboard
# ─────────────────────────────────────────────────────────────────────────────

# Port (Render sets this automatically — do NOT set manually on Render)
PORT=5000

# URL of the Flask ML server deployed on Render (NO trailing slash)
# Example: https://krishi-ml-server.onrender.com
FLASK_URL=https://your-ml-server.onrender.com

# OpenWeatherMap API key (get free key at openweathermap.org)
OPENWEATHERMAP_API_KEY=your_owm_api_key_here

# Vercel frontend URL — used to restrict CORS (NO trailing slash)
# Example: https://krishi.vercel.app
FRONTEND_URL=https://your-app.vercel.app
